{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "i18n.schema.json",
  "title": "EarnProtocolInfo i18n payload (one locale)",
  "description": "Translated text fields for a single locale. Structurally mirrors the translatable subset of EarnProtocolInfo: description + members[{memberPosition, oneLiner}]. No identifiers, URLs, dates, or enums.",
  "type": "object",
  "additionalProperties": false,
  "required": ["description", "members"],
  "properties": {
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1000
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["memberPosition", "oneLiner"],
        "properties": {
          "memberPosition": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "oneLiner": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          }
        }
      }
    }
  }
}
